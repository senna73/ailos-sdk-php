# Copie este arquivo para .env e preencha com suas credenciais
# cp .env.example .env

# Ambiente da API Ailos
AILOS_ENVIRONMENT=homologacao

# Credenciais da aplicação
AILOS_CONSUMER_KEY=sua-consumer-key
AILOS_CONSUMER_SECRET=seu-consumer-secret

# Credenciais do cooperado
AILOS_URL_CALLBACK=https://sua-aplicacao.com.br/ailos/callback
AILOS_API_KEY_DEVELOPER=seu-uuid-developer
AILOS_CODIGO_COOPERATIVA=0001
AILOS_CODIGO_CONTA=123456
AILOS_SENHA=senha-do-cooperado

# JWT de homologação para testes do callback handler (opcional)
# Obtenha realizando o fluxo completo manualmente uma vez
AILOS_JWT_TEST=