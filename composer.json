{
    "name": "ailos/sdk",
    "description": "Este SDK foi desenvolvido para facilitar a integração com os serviços da Cooperativa Ailos, oferecendo uma interface simples, segura e eficiente para desenvolvedores PHP.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Vinícius de Senna",
            "email": "sennadevinicius@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Ailos\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ailos\\Sdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:unit": "vendor/bin/phpunit --testsuite Unit",
        "test:integration": "vendor/bin/phpunit --testsuite Integration",
        "test:all": "vendor/bin/phpunit",
        "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "quality": [
            "@cs-check",
            "@test:all"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}